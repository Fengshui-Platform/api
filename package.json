{
  "name": "fengshui-api",
  "version": "1.0.0",
  "description": "Fengshui Platform API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "migrate": "tsx src/migrate.ts up",
    "migrate:down": "tsx src/migrate.ts down",
    "migrate:status": "tsx src/migrate.ts status",
    "migrate:prod": "node dist/migrate.js up",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.1",
    "nodemailer": "^6.9.14",
    "openai": "^4.52.7",
    "umzug": "^3.8.3",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.4",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
