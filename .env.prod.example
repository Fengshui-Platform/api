# ════════════════════════════════════════════════════════════
#  PRODUCTION ENV — Copy file này → .env rồi điền thông tin thật
#  cp .env.prod.example .env
# ════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Domain & SSL ─────────────────────────────────────────────
DOMAIN=api.yourdomain.com          # VD: api.fengshui.vn
CERTBOT_EMAIL=your@email.com       # Email nhận thông báo cert
CERTBOT_STAGING=0                  # 1 = test cert (không hợp lệ), 0 = cert thật

# ── Frontend URL (CORS) ──────────────────────────────────────
FRONTEND_URL=https://your-vercel-app.vercel.app
# Nếu đã có domain riêng: FRONTEND_URL=https://fengshui.vn

# ── Database ─────────────────────────────────────────────────
DB_HOST=mysql                       # Tên service trong docker-compose
DB_PORT=3306
DB_NAME=fengshui_db
DB_USER=fengshui_user
DB_PASSWORD=your_strong_db_password

MYSQL_ROOT_PASSWORD=your_strong_root_password   # Khác với DB_PASSWORD

# ── JWT ──────────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_RANDOM_HEX

# ── Encryption (AES-256 cho AI API keys) ─────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_RANDOM_HEX

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password   # App Password, không phải mk Gmail
EMAIL_FROM=noreply@yourdomain.com

# ── Web2M Payment ────────────────────────────────────────────
BANK_NAME=ACB
BANK_NUMBER=0041000332151
BANK_ACCOUNT_HOLDER=DOAN THANH TUAN
BANK_TOKEN=your_web2m_bank_token
BANK_PASSWORD=your_web2m_bank_password
BANK_BACKGROUND=13
IS_MASK=0
API_GET_QR=https://api.web2m.com/quicklink
API_GET_TRANSACTION_V2=https://api.web2m.com/api/v2/transaction

# ── Credit config ────────────────────────────────────────────
CREDIT_VALIDITY_DAYS=50
